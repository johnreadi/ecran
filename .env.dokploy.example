# Variables d'environnement pour Dokploy
# Copiez ce fichier en .env.dokploy et remplissez les valeurs

# ============================================
# OBLIGATOIRE - Générez un secret JWT fort :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================
JWT_SECRET=votre-secret-jwt-tres-long-minimum-64-caracteres-hex

# ============================================
# OPTIONNEL - Configuration avancée
# ============================================

# Origine CORS (déjà configuré dans docker-compose.dokploy.yml)
# CORS_ORIGIN=https://ecran.readi.fr

# Environnement Node.js
# NODE_ENV=production

# Port API (déjà configuré dans docker-compose.dokploy.yml)
# PORT=3003
